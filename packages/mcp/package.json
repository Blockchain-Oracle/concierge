{
  "name": "@concierge/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    },
    "./streamable-http": {
      "types": "./dist/streamable-http.d.ts",
      "import": "./dist/streamable-http.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "concierge-mcp": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@concierge/shared": "workspace:*",
    "@concierge/tools": "workspace:*"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "22.19.20",
    "tsup": "8.5.0",
    "zod": "4.4.3"
  }
}
